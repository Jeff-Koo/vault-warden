### --- Vault Configuration ---
### Domain for the Vaultwarden instance
VW_DOMAIN=

### Admin Panel Password (Argon2id Hash)
### Generate with `docker run --rm -it vaultwarden/server /vaultwarden hash`
VW_ADMIN_TOKEN='$argon2id$v=19$m=65540...'

### Set to 'true' for initial account setup
### After registering an account, it is recommended to set this to 'false'
VW_SIGNUPS_ALLOWED=true


### --- SSO Settings ---
# SSO_ENABLE=true
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_ISSUER_URL=https://authentik.xxx.xxx/application/o/vaultwarden/


### --- Push Notifications Settings ---
# PUSH_ENABLED=
# PUSH_INSTALLATION_ID=
# PUSH_INSTALLATION_KEY=


### --- Postgres Configuration ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=


### --- Restic Configuration ---
### Any S3 Compatible Storage
RESTIC_REPOSITORY='s3:https://<YOUR_CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com/<YOUR_BUCKET_NAME>'
### RESTIC_PASSWORD: encrypts all your backed-up data, file names, directory structures, and metadata
RESTIC_PASSWORD=

### S3 API 憑證 (Restic 借用 AWS 變數名稱來達成 S3 相容)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
